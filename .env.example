# Hermes Agent Docker Environment Variables

# User and Group ID for the container process (default: 10000)
HERMES_UID=1000
HERMES_GID=1000

# OpenAI-compatible API Server (Optional)
API_SERVER_HOST=0.0.0.0
# API_SERVER_KEY=your_secure_api_key_here

# Microsoft Teams Gateway (Optional)
# Register at https://dev.botframework.com/
# TEAMS_CLIENT_ID=
# TEAMS_CLIENT_SECRET=
# TEAMS_TENANT_ID=
# TEAMS_ALLOWED_USERS=user1@domain.com,user2@domain.com
# TEAMS_PORT=3978

# Google Chat Gateway (Optional)
# See documentation for full setup details
# GOOGLE_CHAT_PROJECT_ID=
# GOOGLE_CHAT_SUBSCRIPTION_NAME=
# GOOGLE_CHAT_SERVICE_ACCOUNT_JSON=/opt/data/google-chat-sa.json
# GOOGLE_CHAT_ALLOWED_USERS=user1@domain.com

# LLM Providers API Keys
# OpenRouter (https://openrouter.ai/)
OPENROUTER_API_KEY=

# DeepSeek (https://www.deepseek.com/)
DEEPSEEK_API_KEY=

# Other common providers
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GROQ_API_KEY=
